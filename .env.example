# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# App
APP_ENV=development
APP_NAME=LegalHub AI
APP_PORT=3000
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://legalhub:legalhub123@postgres:5432/legalhubdb

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Email (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@legalhubai.uz

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=legalhubai-storage
AWS_S3_URL=https://legalhubai-storage.s3.amazonaws.com

# Payment Providers
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_MERCHANT_KEY=your-payme-merchant-key
PAYME_API_URL=https://checkout.paycom.uz

CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_MERCHANT_KEY=your-click-merchant-key
CLICK_API_URL=https://api.click.uz

# AI Services
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================

NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ==========================================
# DATABASE
# ==========================================

POSTGRES_USER=legalhub
POSTGRES_PASSWORD=legalhub123
POSTGRES_DB=legalhubdb
