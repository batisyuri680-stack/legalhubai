# ==========================================
# APP CONFIGURATION
# ==========================================
APP_ENV=development
APP_NAME=LegalHub AI Backend
APP_PORT=3000
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://legalhub:legalhub123@localhost:5432/legalhubdb
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ==========================================
# JWT TOKENS
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ==========================================
# SECURITY
# ==========================================
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# EMAIL
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=LegalHub AI
MAIL_FROM_EMAIL=noreply@legalhubai.uz

# ==========================================
# AWS S3
# ==========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=legalhubai-storage
AWS_S3_URL=https://legalhubai-storage.s3.amazonaws.com
AWS_S3_MAX_FILE_SIZE=52428800

# ==========================================
# PAYMENT PROVIDERS
# ==========================================
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_MERCHANT_KEY=your-payme-merchant-key
PAYME_API_URL=https://checkout.paycom.uz
PAYME_TIMEOUT=1200

CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_MERCHANT_KEY=your-click-merchant-key
CLICK_API_URL=https://api.click.uz
CLICK_TIMEOUT=60

# ==========================================
# AI & EXTERNAL SERVICES
# ==========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ==========================================
# FEATURE FLAGS
# ==========================================
FEATURE_AI_ENABLED=true
FEATURE_PAYMENT_ENABLED=true
FEATURE_KYC_ENABLED=true
FEATURE_2FA_ENABLED=false
